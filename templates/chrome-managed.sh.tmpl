#!/usr/bin/env bash
set -euo pipefail

# Tunnelclaw — Managed launcher for Google Chrome debug profile.
# Generated by chrome-cdp-relay skill.
# Variables substituted at install time: {{PROFILE_DIR}}, {{DEBUG_PORT}}

CHROME_BIN="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
PROFILE_DIR="{{PROFILE_DIR}}"
DEBUG_PORT="{{DEBUG_PORT}}"

mkdir -p "$PROFILE_DIR"

# If debug endpoint is already alive, do nothing — Chrome is healthy.
if curl -fsS "http://127.0.0.1:${DEBUG_PORT}/json/version" >/dev/null 2>&1; then
  exit 0
fi

# Kill any stale Chrome process that was using this profile/port.
pkill -f "Google Chrome.*--remote-debugging-port=${DEBUG_PORT}.*${PROFILE_DIR}" || true
sleep 1

exec "$CHROME_BIN" \
  --remote-debugging-address=127.0.0.1 \
  --remote-debugging-port="$DEBUG_PORT" \
  --user-data-dir="$PROFILE_DIR" \
  --no-first-run \
  --no-default-browser-check \
  --disable-background-networking
